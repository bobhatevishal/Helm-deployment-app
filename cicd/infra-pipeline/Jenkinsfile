pipeline {
    agent any

    parameters {
        choice(name: 'ENVIRONMENT', choices: ['dev', 'qa', 'uat', 'prod', 'dr'], description: 'Deployment environment')
        choice(name: 'ACTION', choices: ['plan', 'apply', 'destroy'], description: 'Terraform action')
        booleanParam(name: 'AUTO_APPROVE', defaultValue: false, description: 'Auto approve apply/destroy actions')
    }

    environment {
        // Service Principal Credentials
        ARM_CLIENT_ID       = credentials('aks_sp_client_id')
        ARM_CLIENT_SECRET   = credentials('aks_sp_secret')
        ARM_TENANT_ID       = credentials('aks_sp_tenant_id')
        VAR_FILE      = "infrastructure/terraform.tfvars"
        PLAN_FILE     = "${ENVIRONMENT}.plan"
    }

    stages {
        stage('Azure Login') {
            environment {
                // Building the credential ID string here
                SUB_CRED_ID = "subscription_id_${ENVIRONMENT}"
                ARM_SUBSCRIPTION_ID = credentials("${SUB_CRED_ID}")
            }
            steps {
                sh """
                    az login --service-principal \
                        --username "${ARM_CLIENT_ID}" \
                                --password "${ARM_CLIENT_SECRET}" \
                                --tenant "${ARM_TENANT_ID}"

                    az account set --subscription "${ARM_SUBSCRIPTION_ID}"
                """
            }
        }

        stage('Terraform Init') {
            steps {
                sh "terraform -chdir=infrastructure init"
            }
        }

        stage('Terraform Validate') {
            steps {
                sh "terraform -chdir=infrastructure validate"
            }
        }

        stage('Terraform Plan') {
            when {
                expression { ACTION in ['plan', 'apply', 'destroy'] }
            }
            environment {
                SUB_CRED_ID = "subscription_id_${ENVIRONMENT}"
                ARM_SUBSCRIPTION_ID = credentials("${SUB_CRED_ID}")
            }
            steps {
                sh """
                    terraform -chdir=infrastructure plan \
                        -var="subscription_id=${ARM_SUBSCRIPTION_ID}" \
                        -var-file="terraform.tfvars" \
                        -out="../${PLAN_FILE}"
                """
            }
        }

        stage('Approval Required') {
            when {
                expression { (ACTION in ['apply', 'destroy']) && AUTO_APPROVE == false }
            }
            steps {
                timeout(time: 20, unit: 'MINUTES') {
                    input(
                        message: """Approval required for Terraform action.
                        Environment: ${ENVIRONMENT}
                        Action: ${ACTION}
                        Proceed?"""
                    )
                }
            }
        }

        stage('Terraform Apply') {
            when {
                expression { ACTION == 'apply' }
            }
            steps {
                sh "terraform -chdir=infrastructure apply -auto-approve ../${PLAN_FILE}"
            }
        }

        stage('Terraform Destroy') {
            when {
                expression { ACTION == 'destroy' }
            }
            environment {
                SUB_CRED_ID = "subscription_id_${ENVIRONMENT}"
                ARM_SUBSCRIPTION_ID = credentials("${SUB_CRED_ID}")
            }
            steps {
                sh """
                    terraform -chdir=infrastructure destroy -auto-approve \
                        -var="subscription_id=${ARM_SUBSCRIPTION_ID}" \
                        -var-file="terraform.tfvars"
                """
            }
        }
    }

    post {
        always {
            echo 'Pipeline completed. Cleaning workspace.'
            cleanWs()
        }
        success {
            echo "Terraform completed successfully for ${ENVIRONMENT} with action ${ACTION}"
        }
        failure {
            echo "Terraform failed for ${ENVIRONMENT} with action ${ACTION}"
        }
    }
}
